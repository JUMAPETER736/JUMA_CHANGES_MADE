<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F8FA">

    <!-- ── Sticky Toolbar ── -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        app:elevation="2dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="#FFFFFF"
            app:title="Group Settings"
            app:titleTextColor="#111111"
            app:titleTextAppearance="@style/Toolbar.TitleText" />

    </com.google.android.material.appbar.AppBarLayout>


    <!-- ── Scrollable Body ── -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="40dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ══════════════════════════════════════════
               HERO — Avatar + Group title
               ══════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingTop="28dp"
                android:paddingBottom="20dp">

                <!-- Avatar ring -->
                <RelativeLayout
                    android:layout_width="100dp"
                    android:layout_height="100dp">

                    <!-- Outer ring -->
                    <View
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        android:background="@drawable/circle_ring_blue"
                        android:layout_centerInParent="true" />

                    <androidx.cardview.widget.CardView
                        android:layout_width="88dp"
                        android:layout_height="88dp"
                        android:layout_centerInParent="true"
                        app:cardCornerRadius="44dp"
                        app:cardElevation="0dp">

                        <ImageView
                            android:id="@+id/userAvatar"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            app:srcCompat="@drawable/baseline_groups_24" />
                    </androidx.cardview.widget.CardView>

                    <!-- Camera badge -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/addPhotoWrapper"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_alignParentEnd="true"
                        android:layout_alignParentBottom="true"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="4dp">

                        <ImageView
                            android:id="@+id/addPhoto"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@color/bluejeans"
                            android:padding="5dp"
                            android:scaleType="centerInside"
                            app:srcCompat="@drawable/baseline_camera_alt_24"
                            app:tint="#FFFFFF" />
                    </androidx.cardview.widget.CardView>
                </RelativeLayout>

                <TextView
                    android:id="@+id/groupNameHeaderTV"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Group Name"
                    android:textColor="#111111"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:letterSpacing="-0.02" />

                <TextView
                    android:id="@+id/memberCountTV"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="0 members"
                    android:textColor="#888888"
                    android:textSize="13sp" />

            </LinearLayout>

            <!-- 8dp gap -->
            <View android:layout_width="match_parent"
                android:layout_height="8dp"
                android:background="#F7F8FA" />


            <!-- ══════════════════════════════════════════
                SECTION: Group Info
                ══════════════════════════════════════════ -->

            <!-- Section label -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="14dp"
                android:paddingBottom="6dp"
                android:text="GROUP INFO"
                android:textColor="#999999"
                android:textSize="11sp"
                android:letterSpacing="0.08"
                android:textStyle="bold" />

            <!-- Group Name row -->
            <LinearLayout
                android:id="@+id/myNameBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Group name"
                    android:textColor="@color/bluejeans"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.04" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/myNameTV"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="My Group"
                        android:textColor="#111111"
                        android:textSize="16sp" />

                    <EditText
                        android:id="@+id/myNameET"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:background="@null"
                        android:backgroundTint="@color/bluejeans"
                        android:hint="Enter group name"
                        android:inputType="text"
                        android:maxLines="1"
                        android:textColor="#111111"
                        android:textSize="16sp"
                        android:visibility="gone" />

                    <ImageView
                        android:id="@+id/myNameEditBtn"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginStart="8dp"
                        android:src="@drawable/baseline_edit_24"
                        app:tint="#BBBBBB" />

                </LinearLayout>

            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0" android:layout_marginStart="16dp" />

            <!-- Description row -->
            <LinearLayout
                android:id="@+id/descriptionBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Description"
                    android:textColor="@color/bluejeans"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.04" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:gravity="top"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/myLastNameTV"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Add a description..."
                        android:textColor="#AAAAAA"
                        android:textSize="15sp" />


                    <EditText
                        android:id="@+id/myLastNameET"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:background="@null"
                        android:gravity="top"
                        android:hint="Add a description..."
                        android:inputType="textMultiLine"
                        android:maxLines="5"
                        android:minLines="2"
                        android:textColor="#111111"
                        android:textSize="15sp"
                        android:visibility="gone" />

                    <ImageView
                        android:id="@+id/descriptionEditBtn"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginStart="8dp"
                        android:src="@drawable/baseline_edit_24"
                        app:tint="#BBBBBB" />

                </LinearLayout>

            </LinearLayout>

            <!-- ── Save Changes button ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingBottom="16dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/saveChangesBtn"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Save Changes"
                    android:textAllCaps="false"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:visibility="gone"
                    app:cornerRadius="12dp"
                    android:backgroundTint="@color/bluejeans" />

            </LinearLayout>

            <!-- ══════════════════════════════════════════
                           SECTION: Invite Link  (admin / moderator)
                           ══════════════════════════════════════════ -->
            <TextView
                android:id="@+id/inviteSectionLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="14dp"
                android:paddingBottom="6dp"
                android:text="INVITE LINK"
                android:textColor="#999999"
                android:textSize="11sp"
                android:letterSpacing="0.08"
                android:textStyle="bold"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/inviteLinkSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"
                android:visibility="gone">
                <!-- Link pill -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#F0F4FF"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:layout_marginBottom="12dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/share_svgrepo_com"
                        app:tint="@color/bluejeans" />

                    <TextView
                        android:id="@+id/inviteLinkText"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:ellipsize="end"
                        android:maxLines="2"
                        android:text="Generating link..."
                        android:textColor="#444466"
                        android:textSize="13sp"
                        android:fontFamily="monospace" />

                </LinearLayout>

                <!-- Action buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/copyLinkBtn"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="40dp"
                        android:layout_marginEnd="6dp"
                        android:text="Copy"
                        android:textAllCaps="false"
                        android:textSize="13sp"
                        app:strokeColor="@color/bluejeans"
                        app:cornerRadius="10dp"
                        app:icon="@drawable/copy"
                        app:iconSize="15dp"
                        app:iconTint="@color/bluejeans" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/shareLinkBtn"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="40dp"
                        android:layout_marginEnd="6dp"
                        android:text="Share"
                        android:textAllCaps="false"
                        android:textSize="13sp"
                        app:strokeColor="@color/bluejeans"
                        app:cornerRadius="10dp"
                        app:icon="@drawable/baseline_share_24"
                        app:iconSize="15dp"
                        app:iconTint="@color/bluejeans" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/revokeLinkBtn"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="40dp"
                        android:text="Reset"
                        android:textAllCaps="false"
                        android:textSize="13sp"
                        android:textColor="#E53935"
                        app:strokeColor="#E53935"
                        app:cornerRadius="10dp"
                        app:icon="@drawable/share_svgrepo_com"
                        app:iconSize="15dp"
                        app:iconTint="#E53935"
                        android:visibility="gone" />

                </LinearLayout>

            </LinearLayout>

            <View
                android:id="@+id/inviteLinkDivider"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:background="#F7F8FA"
                android:visibility="gone" />

            <!-- ══════════════════════════════════════════
            SECTION: Group Permissions  (admin only)
            ══════════════════════════════════════════ -->
            <TextView
                android:id="@+id/permissionsSectionLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="14dp"
                android:paddingBottom="6dp"
                android:text="GROUP PERMISSIONS"
                android:textColor="#999999"
                android:textSize="11sp"
                android:letterSpacing="0.08"
                android:textStyle="bold"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/permissionsSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:orientation="vertical"
                android:visibility="gone">
                <!-- Edit Info Lock row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp">

                    <LinearLayout
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="#F0F4FF"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/baseline_edit_24"
                            app:tint="@color/bluejeans" />
                    </LinearLayout>



