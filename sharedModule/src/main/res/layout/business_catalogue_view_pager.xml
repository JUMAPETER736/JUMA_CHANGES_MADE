<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
        >

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            >

            <!-- Image View for Images -->
            <ImageView
                android:id="@+id/iv_media"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:importantForAccessibility="no"
                android:scaleType="centerCrop"
                android:visibility="gone" />


            <!-- Video View for Videos -->
            <VideoView
                android:id="@+id/vv_media"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_centerInParent="true"
                android:visibility="gone" />

            <!-- Video Thumbnail (shows before video plays) -->
            <ImageView
                android:id="@+id/iv_video_thumbnail"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:importantForAccessibility="no"
                android:scaleType="centerCrop"
                android:visibility="gone" />


            <!-- Play Button Overlay -->
            <ImageView
                android:id="@+id/iv_play_button"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_centerInParent="true"
                android:importantForAccessibility="no"
                android:src="@drawable/play"
                android:padding="8dp"
                android:visibility="gone"
                android:clickable="true"
                app:tint="@color/white"
                android:focusable="true" />

            <!-- Video Controls Layout -->
            <LinearLayout
                android:id="@+id/ll_video_controls"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_alignParentBottom="true"
                android:background="@drawable/video_controls_background"
                android:orientation="horizontal"
                android:padding="8dp"
                android:gravity="center_vertical"
                android:visibility="gone">

                <!-- Play/Pause Button -->
                <ImageView
                    android:id="@+id/iv_play_pause"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:importantForAccessibility="no"
                    android:src="@drawable/ic_play"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:padding="4dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:tint="@color/white" />

                <!-- Progress Bar -->
                <SeekBar
                    android:id="@+id/sb_progress"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="8dp"
                    android:progressTint="@color/white"
                    android:thumbTint="@color/white"
                    android:max="100"
                    android:progress="0" />

                <!-- Duration Text -->
                <TextView
                    android:id="@+id/tv_duration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00:00"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    android:fontFamily="monospace" />

                <!-- Mute/Unmute Button -->
                <ImageView
                    android:id="@+id/iv_mute"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginStart="8dp"
                    android:importantForAccessibility="no"
                    android:src="@drawable/ic_volume_up"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:padding="4dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:tint="@color/white" />

            </LinearLayout>

            <!-- Video Type Indicator -->
            <TextView
                android:id="@+id/tv_video_indicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentTop="true"
                android:layout_alignParentStart="true"
                android:layout_margin="8dp"
                android:background="@drawable/media_type_background"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:text="VIDEO"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <!-- Loading Progress -->
            <ProgressBar
                android:id="@+id/pb_loading"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_centerInParent="true"
                android:visibility="gone" />

            <!-- Error State -->
            <LinearLayout
                android:id="@+id/ll_error_state"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:orientation="vertical"
                android:gravity="center"
                android:visibility="gone">

                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:importantForAccessibility="no"
                    android:src="@drawable/ic_error_"
                    app:tint="@color/gray_second" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Unable to load media"
                    android:textColor="@color/gray_second"
                    android:textSize="12sp"
                    android:layout_marginTop="8dp" />

                <TextView
                    android:id="@+id/tv_retry"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tap to retry"
                    android:textColor="@color/primary_color"
                    android:textSize="12sp"
                    android:layout_marginTop="4dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground"
                    android:padding="4dp" />

            </LinearLayout>


        </RelativeLayout>

    </RelativeLayout>


