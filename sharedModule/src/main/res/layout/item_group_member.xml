<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/selectableItemBackground"
    android:padding="12dp">

    <!-- Avatar -->
    <ImageView
        android:id="@+id/memberAvatar"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:scaleType="centerCrop"
        app:srcCompat="@drawable/user"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:ignore="ContentDescription" />

    <!-- Name -->
    <TextView
        android:id="@+id/memberName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:text="Member Name"
        android:textColor="#111111"
        android:textSize="15sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium"
        app:layout_constraintStart_toEndOf="@id/memberAvatar"
        app:layout_constraintEnd_toStartOf="@id/memberMutedBadge"
        app:layout_constraintTop_toTopOf="@id/memberAvatar"
        app:layout_constraintBottom_toTopOf="@id/memberUsername" />

    <!-- Username / subtitle row -->
    <TextView
        android:id="@+id/memberUsername"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:text="\@username"
        android:textColor="#888888"
        android:textSize="13sp"
        app:layout_constraintStart_toEndOf="@id/memberAvatar"
        app:layout_constraintEnd_toStartOf="@id/memberMutedBadge"
        app:layout_constraintTop_toBottomOf="@id/memberName"
        app:layout_constraintBottom_toBottomOf="@id/memberAvatar" />


    <!--
            memberRoleLabel  — replaces the old "roleBadge" id.
            The adapter sets text to "Admin" or "Moderator" and hides it for plain members.
            Tint changes per role via adapter (or you can do it in XML with a selector).
        -->
    <TextView
        android:id="@+id/memberRoleLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="3dp"
        android:paddingBottom="3dp"
        android:text="Admin"
        android:textColor="@android:color/white"
        android:textSize="11sp"
        android:textStyle="bold"
        android:background="@drawable/role_badge_bg"
        android:visibility="gone"
        app:layout_constraintEnd_toStartOf="@id/memberMoreBtn"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:visibility="visible" />

    <!--
        memberMutedBadge — small 🔇 icon shown when isMuted == true.
        Sits between the name/username column and the role label.
    -->
    <TextView
        android:id="@+id/memberMutedBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="6dp"
        android:text="🔇"
        android:textSize="13sp"
        android:visibility="gone"
        app:layout_constraintEnd_toStartOf="@id/memberRoleLabel"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:visibility="visible" />

    