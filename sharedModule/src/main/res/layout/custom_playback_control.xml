<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="bottom"
    android:background="@drawable/gradient_bottom"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingTop="24dp"
    android:paddingEnd="16dp"
    android:paddingBottom="16dp">

    <!-- Seekbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@id/exo_position"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:includeFontPadding="false"
            android:paddingEnd="8dp"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold" />

        <androidx.media3.ui.DefaultTimeBar
            android:id="@id/exo_progress"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            app:buffered_color="#80FFFFFF"
            app:played_color="@color/blueJeans"
            app:scrubber_color="@color/blueJeans"
            app:unplayed_color="#4DFFFFFF" />

        <TextView
            android:id="@id/exo_duration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:includeFontPadding="false"
            android:paddingStart="8dp"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold" />

    </LinearLayout>


    <!-- Control Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:orientation="horizontal">

        <!-- Rewind Button -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="24dp"
            app:cardBackgroundColor="#40FFFFFF"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp">

            <ImageButton
                android:id="@id/exo_rew"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="12dp"
                android:src="@drawable/exo_ic_rewind"
                app:tint="#FFFFFF" />

        </com.google.android.material.card.MaterialCardView>

        <!-- Play/Pause Button -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="64dp"
            android:layout_height="64dp"
            app:cardBackgroundColor="@color/blueJeans"
            app:cardCornerRadius="32dp"
            app:cardElevation="8dp">

            <ImageButton
                android:id="@id/exo_play_pause"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="16dp"
                android:src="@drawable/exo_ic_play_circle_filled"
                app:tint="#FFFFFF" />

        </com.google.android.material.card.MaterialCardView>

        <!-- Forward Button -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="24dp"
            app:cardBackgroundColor="#40FFFFFF"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp">

            <ImageButton
                android:id="@id/exo_ffwd"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="12dp"
                android:src="@drawable/exo_ic_forward"
                app:tint="#FFFFFF" />

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>


    <!-- Fullscreen Button (Optional) -->
    <ImageButton
        android:id="@id/exo_fullscreen"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_gravity="end"
        android:layout_marginTop="8dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/exo_ic_fullscreen_enter"
        android:visibility="gone"
        app:tint="#FFFFFF" />

</LinearLayout>