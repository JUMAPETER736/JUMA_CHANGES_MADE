<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@drawable/personal_chat_white_default_background">

    <RelativeLayout
        android:id="@+id/container"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <com.google.android.material.appbar.AppBarLayout
            android:id="@+id/toolbar_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/bluejeans"
            android:elevation="@dimen/sub_title_text_size"
            android:fitsSystemWindows="true">

            <com.google.android.material.appbar.MaterialToolbar
                android:id="@+id/toolbar"
                style="@style/Widget.MaterialComponents.Toolbar.Primary"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize" />

        </com.google.android.material.appbar.AppBarLayout>

        <com.uyscuti.social.chatsuit.messages.MessagesList
            android:id="@+id/messagesList"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_below="@id/toolbar_layout"
            android:layout_above="@+id/inputContainer"
            app:dateHeaderFormat="dd MMMM yyyy"
            app:incomingDefaultBubbleColor="#7F8080"
            app:incomingDefaultBubblePressedColor="#7F8080"
            app:incomingDefaultBubbleSelectedColor="#7F8080"
            app:incomingDefaultImageOverlayPressedColor="@color/black_10"
            app:incomingDefaultImageOverlaySelectedColor="@color/gray_transparent"
            app:incomingTextColor="#FFFFFF"
            app:incomingTextLinkColor="#FFFFFF"
            app:incomingTextSize="16sp"
            app:outcomingDefaultBubbleColor="@color/bluejeans"
            app:outcomingDefaultBubblePressedColor="@color/bluejeans"
            app:outcomingDefaultBubbleSelectedColor="@color/gray_dark_transparent"
            app:outcomingDefaultImageOverlayPressedColor="@color/black_10"
            app:outcomingDefaultImageOverlaySelectedColor="@color/gray_transparent"
            app:outcomingTextColor="@color/white"
            app:outcomingTextLinkColor="@color/white"
            app:outcomingTextSize="16sp"
            app:textAutoLink="all" />

        <!-- ── Input area ─────────────────────────────────────────────────── -->
        <RelativeLayout
            android:id="@+id/inputContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:background="@color/white">

            <!-- Muted / locked banner — sits at the very top of the input area -->
            <TextView
                android:id="@+id/mutedBanner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_alignParentTop="true"
                android:background="#FFF3CD"
                android:gravity="center"
                android:padding="10dp"
                android:text="You have been muted."
                android:textColor="#856404"
                android:textSize="13sp"
                android:visibility="gone" />

            <!-- Input row — sits below the banner -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/mutedBanner"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="8dp">

                <!-- Text field + emoji + attachment -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/edittext_design"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="4dp"
                    android:paddingEnd="4dp">

                    <ImageView
                        android:id="@+id/emoji"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_margin="8dp"
                        android:background="@drawable/baseline_insert_emoticon_24_blue_jeans"
                        app:tint="@color/bluejeans" />

                    <com.vanniktech.emoji.EmojiEditText
                        android:id="@+id/inputEditText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@android:color/transparent"
                        android:gravity="center_vertical"
                        android:hint="Message..."
                        android:imeOptions="actionSend"
                        android:inputType="textCapSentences|textMultiLine"
                        android:maxHeight="120dp"
                        android:maxLines="4"
                        android:minHeight="40dp"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:textColorHint="#808080"
                        android:textSize="16sp" />

                    <ImageView
                        android:id="@+id/attachment"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_margin="8dp"
                        android:background="@drawable/attachment_blue_jeans"
                        app:tint="@color/bluejeans" />

                </LinearLayout>

                <!-- Send button (shown when text is typed) -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/sendCard"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="8dp"
                    android:visibility="gone"
                    app:cardBackgroundColor="@color/bluejeans"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="2dp">

                    <ImageView
                        android:id="@+id/sendBtn"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/send_svgrepo_com__1_"
                        android:visibility="gone"
                        app:tint="@color/white" />

                </androidx.cardview.widget.CardView>

                <!-- Voice note button (shown when text field is empty) -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/vnCard"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="8dp"
                    app:cardBackgroundColor="@color/bluejeans"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="2dp">

                    <ImageView
                        android:id="@+id/voiceNote"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/mic_1"
                        app:tint="@color/white" />

                </androidx.cardview.widget.CardView>

            </LinearLayout>

        </RelativeLayout>
        <!-- ── End input area ─────────────────────────────────────────────── -->

    </RelativeLayout>

    <!-- Legacy second message box (kept for back-compat, hidden by default) -->
    <RelativeLayout
        android:id="@+id/messageBox"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_alignParentBottom="true"
        android:layout_margin="8dp"
        android:gravity="center_vertical"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/messageBoxLayout"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="45dp"
                android:layout_gravity="center_vertical"
                android:layout_weight="1"
                android:background="@drawable/edittext_design"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/emoji2"
                    android:layout_width="25dp"
                    android:layout_height="25dp"
                    android:layout_gravity="center_vertical"
                    android:layout_margin="10dp"
                    android:background="@drawable/baseline_insert_emoticon_24"
                    app:tint="@color/bluejeans" />

                <com.vanniktech.emoji.EmojiEditText
                    android:id="@+id/messageEdit2"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_gravity="center_vertical"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:gravity="center_vertical"
                    android:hint="Type a Message..."
                    android:imeOptions="actionSend"
                    android:inputType="textCapSentences|textMultiLine"
                    android:maxLines="4"
                    android:padding="8dp"
                    android:paddingStart="20dp"
                    android:textSize="16sp" />

                <ImageView
                    android:id="@+id/attachment2"
                    android:layout_width="25dp"
                    android:layout_height="25dp"
                    android:layout_gravity="center_vertical"
                    android:layout_margin="8dp"
                    android:background="@drawable/attachment__2_"
                    app:tint="@color/bluejeans" />

            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:id="@+id/sendCard2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_marginLeft="5dp"
                android:gravity="end"
                android:padding="4dp"
                android:visibility="gone"
                app:cardCornerRadius="20dp"
                app:contentPadding="8dp">

                <ImageView
                    android:id="@+id/sendBtn2"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:src="@drawable/send_svgrepo_com__1_"
                    android:visibility="gone"
                    app:tint="@color/bluejeans" />

            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/vnCard2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_marginLeft="5dp"
                android:gravity="end"
                android:padding="4dp"
                app:cardCornerRadius="20dp"
                app:contentPadding="8dp">

                <ImageView
                    android:id="@+id/voiceNote2"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:src="@drawable/mic_1"
                    app:tint="@color/bluejeans" />

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </RelativeLayout>

    <!-- Voice note recording sheet -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/VNBottomSheetLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:elevation="18dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="1.0">

            <LinearLayout
                android:id="@+id/VNLinearLayout"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/rounded_corners_vn"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/recordingLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="6dp"
                    android:layout_marginEnd="16dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="8dp"
                    android:visibility="visible">

                    <TextView
                        android:id="@+id/recordingTimerTv"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="12dp"
                        android:text="00:00"
                        android:textColor="@color/blueJeans"
                        android:textSize="16sp"
                        android:visibility="visible" />

                    <LinearLayout
                        android:id="@+id/playVNRecorded"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:visibility="gone">

                        <ImageView
                            android:id="@+id/playVnAudioBtn"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_marginEnd="12dp"
                            android:padding="4dp"
                            android:src="@drawable/play_svgrepo_com"
                            app:tint="@color/blueJeans" />

                        <TextView
                            android:id="@+id/pausedTimerTv"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="12dp"
                            android:text="00:00"
                            android:textColor="@color/blueJeans"
                            android:textSize="16sp" />

                    </LinearLayout>

                    <HorizontalScrollView
                        android:id="@+id/waveformScrollView"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:scrollbars="none">

                        <LinearLayout
                            android:id="@+id/waveDotsContainer"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingEnd="8dp"
                            tools:ignore="RtlSymmetry" />

                    </HorizontalScrollView>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <com.uyscuti.sharedmodule.utils.waveformseekbar.WaveformSeekBar
                        android:id="@+id/wave"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_weight="1"
                        android:scaleY="1.8"
                        android:visibility="gone"
                        app:wave_background_color="@color/blueJeans"
                        app:wave_corner_radius="2dp"
                        app:wave_gap="6dp"
                        app:wave_gravity="center"
                        app:wave_min_height="16dp"
                        app:wave_progress_color="@color/blueJeans"
                        app:wave_width="4dp"
                        tools:ignore="MissingClass" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/deleteVN"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_gravity="center"
                        android:layout_marginStart="16dp"
                        android:background="@drawable/ic_ripple"
                        android:padding="5dp"
                        android:src="@drawable/delete_24"
                        app:tint="@color/white" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1" />

                    <ImageView
                        android:id="@+id/recordVN"
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:layout_gravity="center"
                        android:background="@drawable/ic_ripple"
                        android:padding="10dp"
                        android:src="@drawable/ic_mic_on"
                        app:tint="@color/white" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1" />

                    <ImageView
                        android:id="@+id/sendVN"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_gravity="center"
                        android:layout_marginEnd="16dp"
                        android:background="@drawable/ic_ripple_disabled"
                        android:padding="8dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/send_svgrepo_com__1_"
                        app:tint="@color/white" />

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

</RelativeLayout>