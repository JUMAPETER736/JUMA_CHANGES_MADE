<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardElevation="@dimen/card_elevation">

    <!-- Main Repost Container -->
    <LinearLayout
        android:id="@+id/repostContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground">

        <!-- Header Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/header_height"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="@dimen/header_padding_horizontal"
            android:background="@color/blueJeans">

            <!-- Back Button -->
            <ImageButton
                android:id="@+id/cancelButton"
                android:layout_width="@dimen/header_button_size"
                android:layout_height="@dimen/header_button_size"
                android:background="@android:color/transparent"
                android:src="@drawable/cancel_svgrepo_com"
                android:contentDescription="Back"
                app:tint="@android:color/white"/>

            <!-- Post Title -->
            <TextView
                android:id="@+id/headerTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Post"
                android:textColor="@android:color/white"
                android:textSize="@dimen/header_text_size"
                android:textStyle="bold"
                android:gravity="center" />

            <!-- Menu Button -->
            <ImageButton
                android:id="@+id/headerMenuButton"
                android:layout_width="@dimen/header_button_size"
                android:layout_height="@dimen/header_button_size"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/options_vertical_svgrepo_com"
                android:contentDescription="More options"
                app:tint="@android:color/white"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <!-- Content Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/content_padding">

            <!-- User Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/userProfileImage"
                    android:layout_width="@dimen/profile_image_size"
                    android:layout_height="@dimen/profile_image_size"
                    android:src="@drawable/ic_flash" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/small_margin"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/repostedUserName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Unknown User"
                        android:textColor="@color/black"
                        android:textSize="@dimen/username_text_size"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvUserHandle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="\@contentCreator"
                        android:textColor="@color/gray_dark"
                        android:textSize="@dimen/handle_text_size" />
                </LinearLayout>

                <!-- Wrap both date and button to allow flexible alignment -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginEnd="@dimen/medium_margin">

                    <TextView
                        android:id="@+id/date_time_create"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="date_time"
                        android:textSize="@dimen/timestamp_text_size"
                        android:layout_marginEnd="@dimen/small_margin" />

                    <!-- Follow Button - wraps content, no squeezing -->
                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/followButton"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:minWidth="100dp"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:background="@drawable/follow_button_background"
                        android:text="Follow"
                        android:textAlignment="center"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:clickable="true"
                        android:focusable="true"
                        android:elevation="2dp"
                        android:stateListAnimator="@null"/>

                </LinearLayout>
            </LinearLayout>


            <!-- Post Content -->
            <TextView
                android:id="@+id/tvPostTag"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/medium_margin"
                android:text="📱 Had to Repost This! 📱"
                android:textColor="@color/black"
                android:textSize="@dimen/post_text_size" />

            <TextView
                android:id="@+id/userComment"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/medium_margin"
                android:text="Couldn't agree more! [Software Name] is truly a game-changer..."
                android:textColor="@color/black"
                android:textSize="@dimen/body_text_size" />

            <!-- Hashtags -->
            <TextView
                android:id="@+id/tvHashtags"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/medium_margin"
                android:visibility="gone"
                android:text="#Repost #GreatSoftware #MustTry"
                android:textColor="@color/blueJeans"
                android:textSize="@dimen/hashtag_text_size" />

            <!-- Media Container -->
            <androidx.cardview.widget.CardView
                android:id="@+id/mixedFilesCardViews"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/medium_margin"
                android:clickable="true"
                android:visibility="gone"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:cardElevation="@dimen/card_elevation">

                <ImageView
                    android:id="@+id/originalFeedImages"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:adjustViewBounds="true"
                    android:maxHeight="@dimen/media_max_height"
                    android:scaleType="centerCrop"
                    android:contentDescription="Repost media"
                    android:src="@drawable/imageplaceholder"
                    android:visibility="gone"/>

                <LinearLayout
                    android:id="@+id/multipleMediaContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/multipleAudiosContainers"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerViews"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clickable="false"
                    android:nestedScrollingEnabled="false"
                    android:visibility="gone"
                    app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                    app:spanCount="3" />
            </androidx.cardview.widget.CardView>

            <!-- Quoted Post -->
            <androidx.cardview.widget.CardView
                android:id="@+id/quotedPostCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/medium_margin"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:cardElevation="@dimen/card_elevation"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <LinearLayout
                    android:id="@+id/originalPostContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/content_padding"
                    android:background="@color/white">

                    <!-- Quoted User Header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="@dimen/small_margin">

                        <ImageView
                            android:id="@+id/originalPosterProfileImage"
                            android:layout_width="@dimen/quoted_profile_size"
                            android:layout_height="@dimen/quoted_profile_size"
                            android:src="@drawable/ic_flash" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/small_margin"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/originalPosterName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Unknown User"
                                android:textColor="@color/black"
                                android:textSize="@dimen/quoted_username_size"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvQuotedUserHandle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="\@Software$Developer"
                                android:textColor="@color/gray_dark"
                                android:textSize="@dimen/quoted_handle_size" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/date_time"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="date_time"
                            android:textSize="@dimen/quoted_timestamp_size"
                            android:textColor="@color/gray_dark"/>
                    </LinearLayout>

                    <!-- Quoted Content -->
                    <TextView
                        android:id="@+id/originalPostText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/xsmall_margin"
                        android:text="Big shoutout to Social Circuit App..."
                        android:textColor="@color/black"
                        android:textSize="@dimen/quoted_body_size" />

                    <TextView
                        android:id="@+id/tvQuotedHashtags"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/small_margin"
                        android:visibility="gone"
                        android:text="#SoftwareAppreciation #GameChanger"
                        android:textColor="@color/blueJeans"
                        android:textSize="@dimen/quoted_hashtag_size" />

                    <!-- Quoted Media -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/mixedFilesCardView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/small_margin"
                        android:clickable="true"
                        android:visibility="gone"
                        app:cardCornerRadius="@dimen/card_corner_radius"
                        app:cardElevation="0dp">

                        <ImageView
                            android:id="@+id/originalFeedImage"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:adjustViewBounds="true"
                            android:maxHeight="@dimen/quoted_media_max_height"
                            android:scaleType="centerCrop"
                            android:contentDescription="Original post media"
                            android:src="@drawable/imageplaceholder"
                            android:visibility="gone" />

                        <FrameLayout
                            android:id="@+id/videoContainer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:visibility="gone">
                        </FrameLayout>

                        <LinearLayout
                            android:id="@+id/multipleAudiosContainer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:visibility="gone">
                        </LinearLayout>

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/recyclerView"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:clickable="false"
                            android:nestedScrollingEnabled="false"
                            android:visibility="gone"
                            app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                            app:spanCount="3" />
                    </androidx.cardview.widget.CardView>

                    <ImageView
                        android:id="@+id/ivQuotedPostImage"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/legacy_image_height"
                        android:layout_marginTop="@dimen/small_margin"
                        android:scaleType="centerCrop"
                        android:visibility="gone"
                        android:src="@drawable/imageplaceholder" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Action Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingVertical="@dimen/action_bar_padding_vertical"
                android:layout_marginTop="@dimen/medium_margin">

                <!-- Like -->
                <LinearLayout
                    android:id="@+id/likeSection"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:padding="@dimen/action_item_padding">

                    <ImageView
                        android:id="@+id/like"
                        android:layout_width="@dimen/action_icon_size"
                        android:layout_height="@dimen/action_icon_size"
                        android:contentDescription="Like"
                        android:src="@drawable/heart_svgrepo_com"
                        app:tint="@color/blueJeans" />

                    <TextView
                        android:id="@+id/likesCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/action_text_margin"
                        android:text="0"
                        android:textColor="#657786"
                        android:textSize="@dimen/action_text_size" />
                </LinearLayout>

                <!-- Comment -->
                <LinearLayout
                    android:id="@+id/commentSection"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:padding="@dimen/action_item_padding">

                    <ImageView
                        android:id="@+id/comment"
                        android:layout_width="@dimen/action_icon_size"
                        android:layout_height="@dimen/action_icon_size"
                        android:contentDescription="Comment"
                        android:src="@drawable/comments"
                        app:tint="@color/blueJeans" />

                    <TextView
                        android:id="@+id/commentCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/action_text_margin"
                        android:text="0"
                        android:textColor="#657786"
                        android:textSize="@dimen/action_text_size" />
                </LinearLayout>

                <!-- Favorite -->
                <LinearLayout
                    android:id="@+id/favoriteSection"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:padding="@dimen/action_item_padding">

                    <ImageView
                        android:id="@+id/fav"
                        android:layout_width="@dimen/action_icon_size"
                        android:layout_height="@dimen/action_icon_size"
                        android:contentDescription="Favorite"
                        android:src="@drawable/favorite_svgrepo_com__1_"
                        app:tint="@color/blueJeans" />

                    <TextView
                        android:id="@+id/favCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/action_text_margin"
                        android:text="0"
                        android:textColor="#657786"
                        android:textSize="@dimen/action_text_size" />
                </LinearLayout>

                <!-- Repost -->
                <LinearLayout
                    android:id="@+id/retweetSection"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:padding="@dimen/action_item_padding">

                    <ImageView
                        android:id="@+id/reFeed"
                        android:layout_width="@dimen/action_icon_size"
                        android:layout_height="@dimen/action_icon_size"
                        android:contentDescription="Repost"
                        android:src="@drawable/repeat_svgrepo_com"
                        app:tint="@color/blueJeans" />

                    <TextView
                        android:id="@+id/repostCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/action_text_margin"
                        android:text="0"
                        android:textColor="#657786"
                        android:textSize="@dimen/action_text_size" />
                </LinearLayout>

                <!-- Share -->
                <LinearLayout
                    android:id="@+id/shareSection"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:padding="@dimen/action_item_padding"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless">

                    <ImageView
                        android:id="@+id/share"
                        android:layout_width="@dimen/action_icon_size"
                        android:layout_height="@dimen/action_icon_size"
                        android:contentDescription="Share"
                        android:src="@drawable/share_svgrepo_com"
                        app:tint="@color/blueJeans" />

                    <TextView
                        android:id="@+id/shareCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/action_text_margin"
                        android:text="0"
                        android:textColor="#657786"
                        android:textSize="@dimen/action_text_size" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>