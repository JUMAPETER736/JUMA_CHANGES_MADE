<?xml version="1.0" encoding="utf-8"?>
<FrameLayout    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        >

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            tools:ignore="UselessParent">


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                tools:ignore="UselessParent">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="350dp">

                    <androidx.viewpager2.widget.ViewPager2
                        android:id="@+id/viewPager"
                        android:layout_width="match_parent"
                        android:layout_height="350dp" />

                    <com.tbuonomo.viewpagerdotsindicator.WormDotsIndicator
                        android:id="@+id/worm_dots_indicator"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|center"
                        android:layout_marginBottom="16dp"
                        android:padding="8dp"
                        app:dotsColor="@color/blueJeans"
                        app:dotsCornerRadius="8dp"
                        app:dotsSize="16dp"
                        app:dotsSpacing="4dp"
                        app:dotsStrokeColor="@color/white_three"
                        app:dotsStrokeWidth="2dp" />

                </FrameLayout>

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/upload_button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_margin="16dp"
                    android:fontFamily="@font/robot_bold"
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/blue_button_bg"
                    android:text="@string/upload_profession_profile" />


            </LinearLayout>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_margin="8dp"
                android:padding="24dp"
                android:background="@drawable/gray_background"
                android:layout_height="wrap_content">

                <TextView
                    android:fontFamily="@font/regular_font"
                    android:id="@+id/section_label"
                    android:layout_width="wrap_content"
                    android:textAllCaps="true"
                    android:textSize="11sp"
                    android:paddingBottom="16dp"
                    android:text="@string/whats_your_business_profession_name"
                    android:layout_height="wrap_content"/>


                <EditText
                    android:fontFamily="@font/regular_font"
                    android:id="@+id/business_name"
                    android:background="@drawable/style_edit_text"
                    android:layout_width="match_parent"
                    android:padding="8dp"
                    android:textSize="13sp"
                    android:hint="@string/business_profession"
                    android:layout_below="@id/section_label"
                    android:layout_height="wrap_content"/>
            </RelativeLayout>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_margin="8dp"
                android:padding="24dp"
                android:background="@drawable/gray_background"
                android:layout_height="wrap_content">

                <TextView
                    android:fontFamily="@font/regular_font"
                    android:id="@+id/text_business_type"
                    android:layout_width="wrap_content"
                    android:textAllCaps="true"
                    android:textSize="11sp"
                    android:paddingBottom="12dp"
                    android:text="@string/what_s_your_business_profession_type"
                    android:layout_height="wrap_content"/>
                <EditText
                    android:fontFamily="@font/regular_font"
                    android:id="@+id/business_type"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/style_edit_text"
                    android:layout_below="@id/text_business_type"
                    android:hint="@string/business_profession_type"
                    android:padding="8dp"
                    android:textSize="13sp" />



            </RelativeLayout>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_margin="8dp"
                android:padding="24dp"
                android:background="@drawable/gray_background"
                android:layout_height="wrap_content">

                <TextView
                    android:fontFamily="@font/regular_font"
                    android:id="@+id/section_label1"
                    android:layout_width="wrap_content"
                    android:textAllCaps="true"
                    android:textSize="11sp"
                    android:paddingBottom="16dp"
                    android:text="@string/describe_your_business"
                    android:layout_height="wrap_content"/>


                <EditText
                    android:fontFamily="@font/regular_font"
                    android:id="@+id/description_edit"
                    android:background="@drawable/style_edit_text"
                    android:layout_width="match_parent"
                    android:padding="8dp"
                    android:focusable="true"
                    android:textSize="13sp"
                    android:hint="@string/business_description"
                    android:layout_below="@id/section_label1"
                    android:layout_height="wrap_content"/>
            </RelativeLayout>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                android:background="@drawable/gray_background"
                android:padding="24dp">

                <TextView
                    android:fontFamily="@font/regular_font"
                    android:id="@+id/section_label2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingBottom="16dp"
                    android:text="@string/what_s_your_contact_details"
                    android:textAllCaps="true"
                    android:textSize="11sp" />


                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/section_label2"
                    android:orientation="vertical">


                    <EditText
                        android:fontFamily="@font/regular_font"
                        android:id="@+id/email"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:background="@drawable/style_edit_text"
                        android:drawableStart="@drawable/baseline_attach_email_24"
                        android:drawablePadding="8dp"
                        android:drawableTint="@color/fade_gray"
                        android:ems="10"
                        android:hint="@string/email_address"
                        android:inputType="textEmailAddress"
                        android:padding="8dp"
                        android:src="@drawable/mail"
                        android:textSize="13sp"
                        app:helperText="Enter a valid email address" />

                    <EditText
                        android:fontFamily="@font/regular_font"
                        android:id="@+id/phonenumber_edit_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:background="@drawable/style_edit_text"
                        android:drawableStart="@drawable/baseline_add_call_24"
                        android:drawablePadding="8dp"
                        android:drawableTint="@color/fade_gray"
                        android:hint="@string/phone_number"
                        android:inputType="phone"
                        android:maxLength="10"
                        android:padding="8dp"
                        android:textSize="13sp" />
                    <EditText
                        android:fontFamily="@font/regular_font"
                        android:id="@+id/address"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/style_edit_text"
                        android:drawableStart="@drawable/location_24"
                        android:drawablePadding="8dp"
                        android:drawableTint="@color/fade_gray"
                        android:hint="@string/address"
                        android:inputType="textPostalAddress"
                        android:padding="8dp"
                        android:textSize="13sp" />
                </LinearLayout>

            </RelativeLayout>

            <RelativeLayout
                android:id="@+id/relative1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                android:background="@drawable/gray_background"
                android:padding="24dp">

                <TextView
                    android:fontFamily="@font/regular_font"
                    android:id="@+id/section_label3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingBottom="16dp"
                    android:text="@string/location"
                    android:textAllCaps="true"
                    android:textSize="13sp"
                    android:textStyle="bold" />


                <TextView
                    android:fontFamily="@font/regular_font"
                    android:id="@+id/business_location"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/section_label3"
                    android:paddingStart="8dp"
                    android:paddingBottom="4dp"
                    android:text="@string/tag_your_business_location" />


                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/business_location_toggle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:padding="30dp"
                    android:textOff="Off"
                    android:textOn="On" />

                <TextView
                    android:fontFamily="@font/regular_font"
                    android:id="@+id/business_location_description"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/business_location"
                    android:hint="@string/tag_where_your_business_is_situated_this_information_can_be_used_for_various_purposes_including_advertising_and_reaching_out_to_potential_customers_in_that_area"
                    android:paddingStart="8dp"
                    android:paddingTop="4dp"
                    android:textSize="12dp" />


                <View
                    android:id="@+id/first_margin"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_below="@id/business_location_description"
                    android:layout_marginTop="16dp"
                    android:background="@color/gray_two" />


                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@+id/first_margin"
                    >


                    <TextView
                        android:fontFamily="@font/regular_font"
                        android:id="@+id/customer_location"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingStart="8dp"
                        android:paddingTop="16dp"
                        android:paddingBottom="4dp"
                        android:text="@string/enable_walking_billboard" />

                    <TextView
                        android:fontFamily="@font/regular_font"
                        android:id="@+id/currence_location_description"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/customer_location"
                        android:hint="@string/by_enabling_this_feature_every_customer_using_flash_app_will_be_receiving_a_notification_with_a_radius_of_5_meters_depending_on_your_current_location_this_will_make_it_easier_to_advertise_your_business_everywhere_you_go"
                        android:paddingStart="8dp"
                        android:paddingTop="4dp"
                        android:textSize="12dp" />

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/current_location_toggle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@+id/customer_location"
                        android:layout_alignParentEnd="true"
                        android:layout_marginTop="-55dp"
                        android:layout_marginEnd="-2dp"
                        android:padding="30dp"
                        android:textOff="Off"
                        android:textOn="On" />
                    <!-- Add toggle buttons -->

                </RelativeLayout>


            </RelativeLayout>

            <RelativeLayout
                android:layout_width="match_parent"
                android:padding="16dp"
                android:layout_height="wrap_content"
                android:layout_marginBottom="70dp"
                android:orientation="vertical">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/save_btn"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/save"
                    android:fontFamily="@font/robot_bold"
                    android:textColor="@color/white"
                    android:background="@drawable/blue_button_bg"
                    android:textSize="13sp"
                    android:gravity="center"/>
            </RelativeLayout>

        </LinearLayout>

    </ScrollView>

    <ProgressBar
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_gravity="center"
        android:indeterminateTint="@color/blueJeans"
        android:id="@+id/business_progress"
        android:visibility="gone"
        />

</FrameLayout>