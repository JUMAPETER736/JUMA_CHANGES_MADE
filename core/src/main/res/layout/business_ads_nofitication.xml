<?xml version="1.0" encoding="utf-8"?>
<!-- res/layout/notification_business_ad.xml -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="250dp"
    android:id="@+id/main_content_area"
    android:minHeight="250dp"
    android:maxHeight="250dp"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/notification_background"
    android:clickable="true"
    android:focusable="true"
    >

    <!-- Business Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <!-- Business Icon/Logo -->
        <ImageView
            android:id="@+id/business_icon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:scaleType="centerCrop"
            android:src="@drawable/sample_shop_image"
             />

        <!-- Business Name and Location -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="10dp">

            <TextView
                android:id="@+id/business_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/sample_business_name"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@android:color/black"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/business_location"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/sample_location_name"
                android:textSize="12sp"
                android:textColor="@android:color/darker_gray"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>

        <!-- Ad Badge -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/ad"
            android:textSize="9sp"
            android:textColor="@android:color/white"
            android:background="@android:color/darker_gray"
            android:paddingStart="5dp"
            android:paddingEnd="5dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:layout_marginStart="6dp" />
    </LinearLayout>

    <!-- Business Description -->
    <TextView
        android:id="@+id/business_description"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/sample_business_description"
        android:textSize="13sp"
        android:textColor="@android:color/black"
        android:maxLines="2"
        android:ellipsize="end"
        android:layout_marginBottom="8dp" />

    <!-- Product Items Grid (3 columns, compact) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp"
        android:weightSum="3">

        <!-- Product Item 1 -->
        <LinearLayout
            android:id="@+id/product_item_1"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="2dp"
            android:gravity="center">

            <ImageView
                android:id="@+id/product_image_1"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:scaleType="centerCrop"
                android:src="@drawable/sample_shop_image"
                />

            <TextView
                android:id="@+id/product_name_1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Product 1"
                android:textSize="10sp"
                android:textColor="@android:color/black"
                android:maxLines="1"
                android:ellipsize="end"
                android:gravity="center"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/product_price_1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MWK 1000000"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#1976D2" />
        </LinearLayout>

        <!-- Product Item 2 -->
        <LinearLayout
            android:id="@+id/product_item_2"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="2dp"
            android:gravity="center">

            <ImageView
                android:id="@+id/product_image_2"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/sample_shop_image"
                android:scaleType="centerCrop"
                 />

            <TextView
                android:id="@+id/product_name_2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Product 2"
                android:textSize="10sp"
                android:textColor="@android:color/black"
                android:maxLines="1"
                android:ellipsize="end"
                android:gravity="center"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/product_price_2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MWK 1000000"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#1976D2" />
        </LinearLayout>

        <!-- Product Item 3 -->
        <LinearLayout
            android:id="@+id/product_item_3"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="2dp"
            android:gravity="center">

            <ImageView
                android:id="@+id/product_image_3"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/sample_shop_image"
                android:scaleType="centerCrop"
                />

            <TextView
                android:id="@+id/product_name_3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Product 3"
                android:textSize="10sp"
                android:textColor="@android:color/black"
                android:maxLines="1"
                android:ellipsize="end"
                android:gravity="center"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/product_price_3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MWK 1000000"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#1976D2" />
        </LinearLayout>
    </LinearLayout>

    <!-- View More & Action Buttons Combined -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/view_more_text"
            android:layout_width="0dp"
            android:layout_weight="2"
            android:layout_height="wrap_content"
            android:text="@string/plus_sample"
            android:textSize="12sp"
            android:textColor="#1976D2"
            android:clickable="true"
            android:focusable="true" />

        <!-- Dismiss Button -->
        <TextView
            android:id="@+id/btn_dismiss"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/dismiss"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/text_hint"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:layout_weight="1"
            android:paddingTop="6dp"
            android:textAllCaps="true"
            android:paddingBottom="6dp"
            android:clickable="true"
            android:focusable="true" />

        <!-- View Details Button -->
        <TextView
            android:id="@+id/btn_view_details"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/view_more"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:textColor="#1976D2"
            android:layout_weight="1"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:layout_marginStart="4dp"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

</LinearLayout>