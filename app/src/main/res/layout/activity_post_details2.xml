<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="@color/black"
    android:id="@+id/shortsViewPager"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    >


    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:id="@+id/videoLayout"
        >

        <androidx.media3.ui.PlayerView
            android:id="@+id/video_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:backgroundTint="@color/black"
            app:resize_mode="fill"
            app:use_controller="false"
            android:visibility="visible"
            tools:ignore="DuplicateIds" >

            <ImageView
                android:id="@+id/videoThumbnail"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/black"
                android:scaleType="centerCrop"
                android:visibility="visible" />
        </androidx.media3.ui.PlayerView>


        <!-- Play/Pause Button -->
        <ImageView
            android:id="@+id/btnPlayPause"
            android:layout_width="150dp"
            android:layout_height="150dp"
            android:layout_gravity="center"
            android:background="?android:attr/selectableItemBackground"
            android:visibility="gone"
            android:src="@drawable/baseline_pause_black"
            app:tint="@color/white" />

        <!-- Right Side Action Icons - TikTok Style with Counters Below -->

        <!-- Like Icon with Counter -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="8dp"
            android:layout_marginBottom="340dp"
            android:orientation="vertical"
            android:gravity="center">

            <ImageButton
                android:id="@+id/btnLike"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:padding="6dp"
                android:scaleType="fitCenter"
                android:background="?android:attr/selectableItemBackground"
                android:src="@drawable/favorite_svgrepo_com"
                android:tag="unfilled"
                />

            <TextView
                android:id="@+id/likeCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="@color/white"
                android:textSize="11sp"
                android:layout_marginTop="0dp"
                android:textStyle="bold"
                android:shadowColor="#80000000"
                android:shadowDx="0"
                android:shadowDy="1"
                android:shadowRadius="2"
                android:gravity="center" />
        </LinearLayout>

        <!-- Comments with Counter -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="8dp"
            android:layout_marginBottom="280dp"
            android:orientation="vertical"
            android:gravity="center">

            <LinearLayout
                android:id="@+id/commentsParentLayout"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:gravity="center"
                android:background="?android:attr/selectableItemBackground">

                <ImageView
                    android:id="@+id/comments"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/chat_round_svgrepo_com_shorts"
                    app:tint="@color/white" />

            </LinearLayout>

            <TextView
                android:id="@+id/commentsCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="@color/white"
                android:textSize="11sp"
                android:layout_marginTop="0dp"
                android:textStyle="bold"
                android:shadowColor="#80000000"
                android:shadowDx="0"
                android:shadowDy="1"
                android:shadowRadius="2"
                android:gravity="center" />
        </LinearLayout>

        <!-- Favorite Icon (Bookmark) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="8dp"
            android:layout_marginBottom="220dp"
            android:orientation="vertical"
            android:gravity="center">

            <ImageButton
                android:id="@+id/favorite"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:padding="6dp"
                android:scaleType="fitCenter"
                android:background="?android:attr/selectableItemBackground"
                android:src="@drawable/favorite_svgrepo_com__1_"
                android:tag="unfilled"
                />

            <TextView
                android:id="@+id/favoriteCounts"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="@color/white"
                android:textSize="11sp"
                android:layout_marginTop="0dp"
                android:textStyle="bold"
                android:shadowColor="#80000000"
                android:shadowDx="0"
                android:shadowDy="1"
                android:shadowRadius="2"
                android:gravity="center" />
        </LinearLayout>

        <!-- Share Button -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="8dp"
            android:layout_marginBottom="160dp"
            android:orientation="vertical"
            android:gravity="center">

            <ImageButton
                android:id="@+id/shareBtn"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:padding="6dp"
                android:scaleType="fitCenter"
                android:background="?android:attr/selectableItemBackground"
                android:src="@drawable/share_svgrepo_com"
                app:tint="@color/white" />

            <TextView
                android:id="@+id/shareCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="@color/white"
                android:textSize="11sp"
                android:layout_marginTop="0dp"
                android:textStyle="bold"
                android:shadowColor="#80000000"
                android:shadowDx="0"
                android:shadowDy="1"
                android:shadowRadius="2"
                android:gravity="center" />
        </LinearLayout>

        <!-- Download Button -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="8dp"
            android:layout_marginBottom="100dp"
            android:orientation="vertical"
            android:gravity="center">

            <com.uyscuti.sharedmodule.utils.videodownload.DownloadButton
                android:id="@+id/downloadBtn"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:padding="6dp"
                android:scaleType="fitCenter"
                android:background="?android:attr/selectableItemBackground"
                android:src="@drawable/download_02_svgrepo_com"
                app:tint="@color/white" />

            <TextView
                android:id="@+id/downloadCounts"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="@color/white"
                android:textSize="11sp"
                android:layout_marginTop="0dp"
                android:textStyle="bold"
                android:shadowColor="#80000000"
                android:shadowDx="0"
                android:shadowDy="1"
                android:shadowRadius="2"
                android:gravity="center" />
        </LinearLayout>

        <!-- Profile and Caption Container -->
        <LinearLayout
            android:id="@+id/profileCaptionContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|start"
            android:layout_marginEnd="70dp"
            android:layout_marginBottom="20dp"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|start"
                android:gravity="center"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/profileImageForShort"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:layout_marginStart="5dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/baseline_person_outline_24" />

                <TextView
                    android:id="@+id/shortUsername"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Username"
                    android:layout_marginStart="8dp"
                    android:textColor="#FFF"
                    android:textStyle="bold"
                    android:shadowColor="#80000000"
                    android:shadowDx="0"
                    android:shadowDy="1"
                    android:shadowRadius="2" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/followButton"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:minWidth="70dp"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:textAllCaps="false"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/shorts_follow_button_border"
                    android:text="Follow"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#FFF" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:id="@+id/tvReadMoreLess"
                    android:textColor="@android:color/white"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:textSize="14sp"
                    android:shadowColor="#80000000"
                    android:shadowDx="0"
                    android:shadowDy="1"
                    android:shadowRadius="2"
                    android:layout_gravity="center"
                    android:text="HERE GIVE YOUR TEXT"/>

            </LinearLayout>

            <!-- Music/Song Info Section with SINGLE SeekBar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="30dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎵 Artist name + Song title"
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    android:layout_marginStart="8dp"
                    android:shadowColor="#80000000"
                    android:shadowDx="0"
                    android:shadowDy="1"
                    android:shadowRadius="2" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="4dp">

                    <androidx.cardview.widget.CardView
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:layout_marginStart="8dp"
                        app:cardCornerRadius="17dp"
                        app:cardElevation="2dp">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/user"
                            android:scaleType="centerCrop"
                            android:adjustViewBounds="true"
                            android:layout_gravity="center"/>

                    </androidx.cardview.widget.CardView>

                    <SeekBar
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="30dp"
                        android:layout_gravity="center"
                        android:id="@+id/bottomShortsVideoProgressSeekBar"
                        android:progressTint="@color/bluejeans"
                        android:progressBackgroundTint="@color/dark_gray"
                        android:max="100"
                        android:progress="0"
                        android:thumb="@null"
                        android:splitTrack="false"
                        android:visibility="visible"
                        android:minHeight="3dp"
                        android:maxHeight="3dp"
                        android:layout_marginStart="8dp"
                        android:layout_marginEnd="8dp" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </FrameLayout>


    <!-- Progress Bar -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:visibility="gone"
        android:layout_height="37dp"
        android:layout_centerInParent="true"
        android:indeterminateTint="@color/blueJeans"
        />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:id="@+id/showError"
        android:layout_centerInParent="true"
        android:text="@string/something_went_wrong"
        android:textSize="@dimen/dimen_16"
        android:textColor="@color/gray_dark"
        android:visibility="gone"
        />

    <androidx.constraintlayout.motion.widget.MotionLayout
        android:id="@+id/motionLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        app:layoutDescription="@xml/activity_main_xml_motionlayout_scene">

        <LinearLayout
            android:id="@+id/linearLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/rounded_corners"
            android:gravity="center"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="1.0"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:layout_width="50dp"
                android:layout_height="2dp"
                android:layout_marginTop="2dp"
                android:src="@drawable/straight_line" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal"
                android:padding="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:padding="1dp"
                    android:text="Comments"
                    android:textColor="@color/black"
                    android:textSize="20sp" />

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/bluejeans" />
        </LinearLayout>


        <RelativeLayout
            android:id="@+id/layout3"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:background="@color/white"
            android:orientation="vertical"
            app:layout_constraintBottom_toTopOf="@+id/linearLayout2"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/linearLayout"
            app:layout_constraintVertical_bias="0.44">

            <com.facebook.shimmer.ShimmerFrameLayout
                android:id="@+id/shimmer_layout"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="visible">

                    <include layout="@layout/short_comments_shimmer_placeholder" />

                    <include layout="@layout/short_comments_shimmer_placeholder" />

                    <include layout="@layout/short_comments_shimmer_placeholder" />

                    <include layout="@layout/short_comments_shimmer_placeholder" />

                    <include layout="@layout/short_comments_shimmer_placeholder" />
                </LinearLayout>

            </com.facebook.shimmer.ShimmerFrameLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_above="@+id/progressBarZ"
                tools:listitem="@layout/comment_text_item" />

            <LinearLayout
                android:id="@+id/placeholderLayout"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/be_the_first_to_comment"
                    android:textColor="@color/black"
                    android:textSize="18sp" />
            </LinearLayout>

            <ProgressBar
                android:id="@+id/progressBarZ"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_alignParentBottom="true"
                android:layout_centerHorizontal="true"
                android:visibility="gone" />
        </RelativeLayout>

        <LinearLayout
            android:id="@+id/linearLayout2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/white"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toStartOf="parent">

            <LinearLayout
                android:id="@+id/replyToLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="1dp"
                android:background="#F4E8E8"
                android:orientation="horizontal"
                android:visibility="gone">

                <TextView
                    android:id="@+id/replyToTextView"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:padding="5dp"
                    android:paddingStart="10dp"
                    android:text="Replying to ..."
                    android:textSize="16dp"
                    android:visibility="visible" />

                <ImageView
                    android:id="@+id/exitReply"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="end|center"
                    android:layout_marginEnd="9dp"
                    android:src="@drawable/times_svgrepo_com__1_exit" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_above="@+id/input"
                android:layout_marginLeft="16dp"
                android:layout_marginRight="16dp"
                android:background="@color/bluejeans" />

            <com.uyscuti.social.chatsuit.messages.CommentsInput
                android:id="@+id/input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="visible"
                app:attachmentButtonDefaultIconColor="@color/bluejeans"
                app:attachmentButtonDefaultIconPressedColor="@color/bluejeans"
                app:inputButtonDefaultBgColor="@color/bluejeans"
                app:inputButtonDefaultBgPressedColor="@color/bluejeans"
                app:inputCursorDrawable="@drawable/shape_custom_cursor"
                app:inputHint="Comment..."
                app:showAttachmentButton="true" />


        </LinearLayout>

        <View
            android:id="@+id/click"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:background="@color/transparent_grayish"
            app:layout_constraintBottom_toTopOf="@+id/linearLayout"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="0.97" />

    </androidx.constraintlayout.motion.widget.MotionLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:id="@+id/VnLayout"
        android:visibility="gone"
        >
        <!--        android:background="#808080"-->


        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="200dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="1.0"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:elevation="18dp"

            >
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:id="@+id/VNLinearLayout"
                android:background="@drawable/rounded_corners_vn"
                >

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="00:00:00"
                    android:gravity="center"
                    android:visibility="visible"
                    android:layout_marginTop="3dp"
                    android:textSize="16sp"
                    android:id="@+id/timerTv"
                    />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:visibility="gone"
                    android:id="@+id/playerTimerTv"
                    >
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="00:00"
                        android:gravity="start"
                        android:layout_marginStart="20dp"
                        android:visibility="visible"
                        android:layout_marginTop="3dp"
                        android:textSize="16sp"
                        android:id="@+id/secondTimerTv"
                        />
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="00:00"
                        android:gravity="end"
                        android:layout_marginEnd="20dp"
                        android:visibility="visible"
                        android:layout_marginTop="3dp"
                        android:textSize="16sp"
                        android:id="@+id/thirdTimerTv"
                        />

                </LinearLayout>

                <com.uyscuti.sharedmodule.views.WaveFormView
                    android:layout_width="match_parent"
                    android:layout_height="90dp"
                    android:layout_marginTop="5dp"
                    android:id="@+id/waveForm"
                    android:visibility="visible"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0.5"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintVertical_bias="0.5" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:id="@+id/playAudioLayout"
                    android:visibility="gone"
                    >

                    <ImageView
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:layout_gravity="center"
                        android:layout_marginStart="30dp"
                        android:id="@+id/playVnAudioBtn"
                        android:background="@drawable/ic_ripple"
                        android:padding="10dp"
                        android:src="@drawable/play_svgrepo_com"
                        app:tint="@color/white"

                        />


                    <com.uyscuti.sharedmodule.utils.waveformseekbar.WaveformSeekBar
                        android:id="@+id/wave"
                        android:layout_width="0dp"
                        android:layout_height="32dp"
                        android:layout_weight="1"
                        android:layout_gravity="center"
                        app:marker_color="@color/fade"
                        android:layout_margin="16dp"
                        app:marker_text_padding="2dp"
                        app:marker_text_size="12dp"
                        app:marker_width="1dp"
                        app:wave_background_color="@color/gray_dark"
                        app:wave_corner_radius="2dp"
                        app:wave_gap="1.5dp"
                        app:wave_gravity="center"
                        app:wave_max_progress="100"
                        app:wave_min_height="3dp"
                        app:wave_progress="0"
                        app:wave_progress_color="@color/bluejeans"
                        app:wave_width="5dp" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="5dp"
                    android:gravity="center"
                    >
                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:id="@+id/deleteVN"
                        android:src="@drawable/times_svgrepo_com__1_exit"
                        app:tint="@color/white"
                        android:background="@drawable/ic_ripple"
                        android:layout_marginStart="10dp"
                        android:layout_gravity="center"
                        android:padding="5dp"
                        />
                    <ImageView
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:src="@drawable/ic_mic_on"
                        android:padding="10dp"
                        app:tint="@color/white"
                        android:id="@+id/recordVN"
                        android:layout_gravity="center"
                        android:layout_marginHorizontal="80dp"
                        android:background="@drawable/ic_ripple"
                        />
                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:padding="8dp"
                        android:src="@drawable/send_svgrepo_com__1_"
                        app:tint="@color/white"
                        android:id="@+id/sendVN"
                        android:scaleType="centerCrop"
                        android:layout_gravity="center"
                        android:background="@drawable/ic_ripple_disabled"
                        android:layout_marginStart="10dp"
                        />
                </LinearLayout>
            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </androidx.constraintlayout.widget.ConstraintLayout>


</RelativeLayout>