<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="24dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header Icon -->
        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_ads"
            app:tint="#1976D2"
            android:contentDescription="@string/advertising_service_icon" />

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/advertising_service_agreement"
            android:textAlignment="center"
            android:textColor="@color/textPrimary"
            android:textSize="22sp"
            android:textStyle="bold" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"
            android:background="#E0E0E0" />

        <!-- Scrollable Content -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="280dp"
            android:scrollbars="vertical"
            android:fadeScrollbars="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Introduction -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/welcome_to_our_advertising_platform"
                    android:textColor="@color/textPrimary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/by_using_our_advertising_services_you_agree_to_promote_your_products_and_services_on_our_platform_s_feed_reaching_millions_of_engaged_users"
                    android:textColor="@color/textSecondary"
                    android:textSize="14sp"
                    android:layout_marginBottom="16dp" />

                <!-- Payment Terms -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/payment_requirements"
                    android:textColor="@color/textPrimary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/all_advertising_campaigns_require_payment_before_activation_n_minimum_campaign_budget_50_usd_n_payment_methods_credit_debit_card_paypal_bank_transfer_n_charges_are_non_refundable_once_campaign_is_live_n_billing_occurs_at_campaign_start_or_monthly_for_ongoing_campaigns"
                    android:textColor="@color/textSecondary"
                    android:textSize="14sp"
                    android:layout_marginBottom="16dp" />

                <!-- Service Terms -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/service_terms"
                    android:textColor="@color/textPrimary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/your_ads_will_appear_in_users_feeds_based_on_targeting_criteria_n_we_reserve_the_right_to_reject_ads_that_violate_our_policies_n_ad_performance_is_not_guaranteed_n_you_retain_all_rights_to_your_ad_content_n_we_may_use_your_ads_for_platform_promotion_examples_n_campaign_can_be_paused_or_cancelled_with_24_hours_notice"
                    android:textColor="@color/textSecondary"
                    android:textSize="14sp"
                    android:layout_marginBottom="16dp" />

                <!-- Content Guidelines -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/content_guidelines"
                    android:textColor="@color/textPrimary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/prohibited_content_includes_misleading_claims_adult_content_illegal_products_hate_speech_violent_imagery_or_content_that_infringes_intellectual_property_rights"
                    android:textColor="@color/textSecondary"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp" />

            </LinearLayout>
        </ScrollView>

        <!-- Checkbox Agreement -->
        <CheckBox
            android:id="@+id/checkboxAgree"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/i_agree_to_the_terms_and_understand_that_payment_is_required"
            android:textColor="@color/textSecondary"
            android:textSize="13sp" />

        <!-- Buttons -->
        <LinearLayout
            style="?android:attr/buttonBarStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal"
            android:gravity="end">

            <Button
                android:id="@+id/btnDecline"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/decline"
                android:textColor="@color/textSecondary"
                android:layout_marginEnd="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAccept"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@color/blueJeans"
                android:backgroundTint="@color/blueJeans"
                android:enabled="false"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:text="@string/accept_amp_continue"
                android:textColor="@android:color/white"
                />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>