<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".RepostBusinessPost">

    <RelativeLayout
        android:layout_width="match_parent"
        android:padding="8dp"
        android:background="@color/blueJeans"
        android:layout_height="wrap_content">

        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:id="@+id/close_repost"
            android:contentDescription="@string/back"
            android:src="@drawable/cancel_svgrepo_com"
            android:layout_centerVertical="true"
            app:tint="@color/white" />


        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/repost_title"
            android:textSize="18sp"
            android:layout_centerInParent="true"
            android:textColor="@color/white"
            android:layout_alignParentEnd="true"
            android:padding="4dp"
            android:id="@+id/repost_business"
            tools:ignore="RelativeOverlap" />
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            >


            <LinearLayout
                android:layout_width="match_parent"
                android:orientation="horizontal"
                android:padding="4dp"
                android:layout_height="wrap_content">

                <androidx.cardview.widget.CardView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="50dp">

                    <ImageView
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:id="@+id/repost_user_avatar"
                        android:contentDescription="@string/user_image"
                        android:src="@drawable/ic_person"
                        />

                </androidx.cardview.widget.CardView>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingStart="8dp"
                    android:layout_gravity="center"
                    android:orientation="vertical"
                    tools:ignore="RtlSymmetry">


                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:id="@+id/reposter_name"
                        android:text="Phygo Phygo"
                        android:textSize="16sp"
                        android:textColor="@color/black"
                        android:textStyle="bold"
                        />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:id="@+id/reposter_username"
                        android:text="godbless"
                        android:textSize="@dimen/body_text_size"
                        android:textColor="@color/gray_dark"
                        />



                </LinearLayout>

            </LinearLayout>

            <EditText
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="@string/add_caption"
                android:background="@drawable/bottom_input_field_blue_color"
                android:importantForAutofill="no"
                android:paddingStart="16dp"
                tools:ignore="RtlSymmetry"
                android:id="@+id/business_caption"
                android:layout_marginTop="4dp"
                android:inputType="text|textAutoComplete|textAutoCorrect"
                />

            <LinearLayout
                android:layout_width="match_parent"
                android:baselineAligned="false"
                android:orientation="horizontal"
                android:layout_marginTop="4dp"
                android:padding="4dp"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:layout_width="0dp"
                    android:orientation="vertical"
                    android:layout_weight="1"
                    android:layout_gravity="bottom"
                    android:id="@+id/tag_people"
                    android:layout_height="wrap_content"
                    tools:ignore="UseCompoundDrawables">

                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:contentDescription="@string/tag_people"
                        android:src="@drawable/baseline_person_outline_24"
                        app:tint="@color/blueJeans"

                        />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="@string/tag_people"
                        android:textColor="@color/black"
                        />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:orientation="vertical"
                    android:layout_weight="1"
                    android:id="@+id/add_topic"
                    android:layout_gravity="bottom"
                    android:layout_height="wrap_content"
                    tools:ignore="UseCompoundDrawables">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:contentDescription="@string/add_topics"
                        android:src="@drawable/topic2_svgrepo_com"
                        app:tint="@color/blueJeans"

                        />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="@string/add_topics"
                        android:textColor="@color/black"
                        />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:orientation="vertical"
                    android:layout_weight="1"
                    android:id="@+id/add_location"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom"
                    tools:ignore="UseCompoundDrawables">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:contentDescription="@string/add_location"
                        android:src="@drawable/baseline_location_on_24"
                        app:tint="@color/blueJeans"

                        />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="@string/add_location"
                        android:textColor="@color/black"
                        />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:orientation="vertical"
                    android:layout_weight="1"
                    android:layout_gravity="bottom"
                    android:id="@+id/add_more"
                    android:layout_height="wrap_content"
                    tools:ignore="UseCompoundDrawables">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:contentDescription="@string/add_more"
                        android:src="@drawable/ic_add_attachment"
                        app:tint="@color/blueJeans"

                        />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="@string/add_more"
                        android:textColor="@color/black"
                        />

                </LinearLayout>




            </LinearLayout>



            <!-- Header Image Section -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:id="@+id/view_pager_layout"
                android:visibility="gone"
                android:layout_height="300dp">

                <androidx.viewpager2.widget.ViewPager2
                    android:layout_width="match_parent"
                    android:id="@+id/media_view_pager"
                    android:layout_height="match_parent"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/gradient_overlay" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_alignParentBottom="true"
                    android:orientation="vertical"
                    >

                    <com.tbuonomo.viewpagerdotsindicator.DotsIndicator
                        android:id="@+id/worm_dots_indicator"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="top|center"
                        android:layout_marginBottom="12dp"
                        android:layout_marginTop="?attr/actionBarSize"
                        app:dotsColor="@color/white_three"
                        app:selectedDotColor="@color/blueJeans"
                        app:dotsCornerRadius="8dp"
                        app:dotsSize="10dp"
                        app:progressMode="false"
                        app:dotsSpacing="2dp"
                        app:dotsStrokeWidth="2dp" />

                </LinearLayout>



            </RelativeLayout>


            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_gravity="bottom"
                android:background="@color/divider" />



            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="0dp"
                app:cardCornerRadius="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- User Header Section -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:id="@+id/user_header"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="16dp">

                        <ImageView
                            android:id="@+id/iv_user_avatar"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/circle_background"
                            android:contentDescription="@string/user_image"
                            android:scaleType="centerCrop"
                            tools:src="@drawable/ic_person" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tv_username"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/black"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                tools:text="Godbless" />


                        </LinearLayout>

                        <TextView
                            android:id="@+id/tv_post_time"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:padding="8dp"
                            android:textColor="@color/gray_second"
                            android:textSize="12sp"
                            tools:text="2 hours ago" />

                    </LinearLayout>

                    <!-- Catalogue Item Info -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:id="@+id/catalogueInfo"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/tv_item_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="4dp"
                            android:textColor="@color/black"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            tools:text="Premium Wireless Headphones" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="4dp"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tv_description"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/test_message"
                                android:textColor="@color/gray_second"
                                android:textSize="16sp" />

                        </LinearLayout>


                        <TextView
                            android:id="@+id/tv_item_price"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            android:textColor="@color/blueJeans"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            tools:text="MWK 299.99" />

                    </LinearLayout>

                    <!-- Media Section (Images/Videos) with ViewPager -->

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_margin="0dp"
                        app:cardCornerRadius="0dp"
                        app:cardElevation="0dp">

                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_margin="0dp"
                            >

                            <androidx.recyclerview.widget.RecyclerView
                                android:id="@+id/business_recycler"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:background="@color/white"
                                android:nestedScrollingEnabled="false"
                                app:layoutManager="androidx.recyclerview.widget.StaggeredGridLayoutManager"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintTop_toTopOf="parent"
                                android:layout_margin="0dp"
                                app:spanCount="3" />


                            <TextView
                                android:id="@+id/tv_media_counter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginRight="16dp"
                                android:layout_marginBottom="12dp"
                                android:paddingLeft="8dp"
                                android:paddingRight="8dp"
                                android:textColor="@color/white"
                                android:textSize="16sp"
                                android:visibility="gone"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintEnd_toEndOf="parent" />

                        </androidx.constraintlayout.widget.ConstraintLayout>


                    </com.google.android.material.card.MaterialCardView>

                    <!-- Interaction Buttons -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:clickable="false"
                        android:id="@+id/reactionLayout"
                        android:paddingVertical="8dp">

                        <!-- Like Button -->
                        <LinearLayout
                            android:id="@+id/ll_like"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="?attr/selectableItemBackground"
                            android:gravity="center"
                            android:clickable="false"
                            android:orientation="horizontal"
                            android:padding="8dp">

                            <ImageView
                                android:id="@+id/bu_like"
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:src="@drawable/heart_svgrepo_com"
                                android:tint="@color/blueJeans"
                                tools:ignore="UseAppTint" />

                            <TextView
                                android:id="@+id/bu_like_count"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:textColor="@color/gray_second"
                                android:textSize="16sp"
                                tools:text="124" />

                        </LinearLayout>

                        <!-- Comment Button -->
                        <LinearLayout
                            android:id="@+id/ll_comment"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="?attr/selectableItemBackground"
                            android:gravity="center"
                            android:clickable="false"
                            android:orientation="horizontal"
                            android:padding="8dp">

                            <ImageView
                                android:id="@+id/bu_comment"
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:src="@drawable/comments"
                                android:tint="@color/blueJeans"
                                tools:ignore="UseAppTint" />

                            <TextView
                                android:id="@+id/bu_comment_count"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:textColor="@color/gray_second"
                                android:textSize="16sp"
                                tools:text="32" />

                        </LinearLayout>

                        <!-- Repost Button -->
                        <LinearLayout
                            android:id="@+id/ll_repost"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="?attr/selectableItemBackground"
                            android:gravity="center"
                            android:clickable="false"
                            android:orientation="horizontal"
                            android:padding="8dp">

                            <ImageView
                                android:id="@+id/bu_book_mark"
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:src="@drawable/favorite_svgrepo_com__1_"
                                app:tint="@color/blueJeans" />

                            <TextView
                                android:id="@+id/bu_book_mark_count"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:textColor="@color/gray_second"
                                android:textSize="16sp"
                                tools:text="18" />

                        </LinearLayout>

                        <!-- Share Button -->
                        <LinearLayout
                            android:id="@+id/ll_share"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="?attr/selectableItemBackground"
                            android:gravity="center"
                            android:clickable="false"
                            android:orientation="horizontal"
                            android:padding="8dp">

                            <ImageView
                                android:id="@+id/bu_repost"
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:src="@drawable/repeat_svgrepo_com"
                                app:tint="@color/blueJeans" />

                            <TextView
                                android:id="@+id/bu_repost_count"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:textColor="@color/gray_second"
                                android:textSize="16sp"
                                tools:text="18" />

                        </LinearLayout>

                        <!-- Bookmark Button -->
                        <LinearLayout
                            android:id="@+id/ll_bookmark"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="?attr/selectableItemBackground"
                            android:gravity="center"
                            android:clickable="false"
                            android:orientation="horizontal"
                            android:padding="8dp">

                            <ImageView
                                android:id="@+id/bu_share"
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:src="@drawable/share_svgrepo_com"
                                android:tint="@color/blueJeans"
                                tools:ignore="UseAppTint" />

                            <TextView
                                android:id="@+id/share_count"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:textColor="@color/gray_second"
                                android:textSize="16sp"
                                tools:text="18" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>






        </LinearLayout>

    </ScrollView>


</LinearLayout>