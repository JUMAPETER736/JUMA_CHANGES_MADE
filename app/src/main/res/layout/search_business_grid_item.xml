<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_margin="4dp"
    android:clickable="true"
    android:focusable="true">

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/businessItemImage"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintDimensionRatio="1:1"
        app:shapeAppearanceOverlay="@style/RoundedCorners12dp"
        android:scaleType="centerCrop"
        tools:src="@drawable/flash21"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/justListedBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Just listed"
        android:textSize="11sp"
        android:textColor="@android:color/white"
        android:textStyle="bold"
        android:padding="4dp"
        android:background="@drawable/just_listed_badge_bg"
        app:layout_constraintTop_toTopOf="@id/businessItemImage"
        app:layout_constraintStart_toStartOf="@id/businessItemImage"
        android:visibility="gone" />

    <TextView
        android:id="@+id/businessItemPrice"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="MWK10,000"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@android:color/white"
        android:shadowColor="#80000000"
        android:shadowDx="0"
        android:shadowDy="2"
        android:shadowRadius="4"
        app:layout_constraintBottom_toBottomOf="@id/businessItemImage"
        app:layout_constraintStart_toStartOf="@id/businessItemImage"
        app:layout_constraintEnd_toEndOf="@id/businessItemImage" />

    <LinearLayout
        android:id="@+id/productDetailsContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp"
        app:layout_constraintTop_toBottomOf="@id/businessItemImage"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/businessItemName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="2"
            android:textSize="14sp"
            android:textColor="#1C1E21"
            tools:text="Tecno Spark 20 smart need $310" />

        <TextView
            android:id="@+id/businessItemLocation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="#65676B"
            android:ellipsize="end"
            android:maxLines="1"
            tools:text="Lilongwe, Malawi" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
